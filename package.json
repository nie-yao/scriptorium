{
  "name": "scriptorium",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "scripts": {
    "build": "npm run build:core && vite build --config apps/web/vite.config.ts",
    "build:core": "tsc -p packages/core/tsconfig.json",
    "dev": "node scripts/dev.mjs",
    "test": "npm run test:core",
    "test:core": "npm run build:core && node packages/core/tests/review.test.mjs"
  },
  "workspaces": [
    "apps/web",
    "packages/core",
    "packages/platform"
  ],
  "dependencies": {
    "@codemirror/commands": "6.3.3",
    "@codemirror/language": "6.10.1",
    "@codemirror/legacy-modes": "6.4.0",
    "@codemirror/search": "6.5.6",
    "@codemirror/state": "6.4.1",
    "@codemirror/view": "6.26.3",
    "codemirror": "6.0.1",
    "lucide-react": "0.468.0",
    "pdfjs-dist": "^3.4.120",
    "react": "18.2.0",
    "react-dom": "18.2.0"
  },
  "devDependencies": {
    "@types/node": "20.11.30",
    "@types/react": "18.2.64",
    "@types/react-dom": "18.2.21",
    "@vitejs/plugin-react": "3.1.0",
    "typescript": "5.1.6",
    "vite": "4.5.3"
  }
}
